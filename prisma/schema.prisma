generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  name       String?
  email      String    @unique
  image      String?
  username   String?   @unique
  role       String    @default("user")
  isArchived Boolean   @default(false)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  biodata    Biodata?
  reports    Report[]
}

model Biodata {
  id         String   @id @default(uuid())
  userId     String   @unique
  language   String   @default("bn")
  isPublic   Boolean  @default(true)
  isReported Boolean  @default(false)
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports    Report[]
}

model Report {
  id         String   @id @default(uuid())
  reporterId String
  biodataId  String
  reason     String?
  createdAt  DateTime @default(now())

  reporter User    @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  biodata  Biodata @relation(fields: [biodataId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([biodataId])
}

model GuestSession {
  id         String          @id @default(uuid())
  sessionId  String          @unique
  userAgent  String?
  ipHash     String?
  lastActive DateTime        @default(now())
  createdAt  DateTime        @default(now())
  activities GuestActivity[]
}

model GuestActivity {
  id        String       @id @default(uuid())
  sessionId String
  type      String
  path      String
  metadata  Json?
  createdAt DateTime     @default(now())
  session   GuestSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId])
}

